# ============================================================
# CTTAF Benchmark — API Keys
# ============================================================
# Copy this file to .env and fill in the keys you need.
# Keys marked [JUDGE] are REQUIRED — they power the dual-judge
# evaluation pipeline for every benchmark run.
# All other keys are only needed when evaluating that provider's models.
# ============================================================

# ── [JUDGE] Required for the dual-judge pipeline ────────────
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Google / Gemini 3.1 Pro, Flash · Gemma 3 ────────────────
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# ── xAI / Grok 4, Grok 4.1 ──────────────────────────────────
# https://console.x.ai/
XAI_API_KEY=your-xai-api-key-here

# ── Mistral AI / Mistral Large, Medium ──────────────────────
# https://console.mistral.ai/
MISTRAL_API_KEY=your-mistral-api-key-here

# ── DeepSeek / DeepSeek-V3.2, R1 ────────────────────────────
# https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ── OpenRouter (aggregator) ──────────────────────────────────
# Used for: Llama 4 family, Qwen 3.6, Gemma 3, Phi-4,
#           and many more open-weight models.
# https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ── Moonshot AI / Kimi K2.6 ─────────────────────────────────
# https://platform.moonshot.cn/
MOONSHOT_API_KEY=your-moonshot-api-key-here

# ── Zhipu AI / GLM-5 ────────────────────────────────────────
# https://open.bigmodel.cn/
ZHIPU_API_KEY=your-zhipu-api-key-here

# ── MiniMax / M2.5, M2.7 ────────────────────────────────────
# https://api.minimax.chat/
MINIMAX_API_KEY=your-minimax-api-key-here

# ── NVIDIA NIM / Nemotron 3 ─────────────────────────────────
# https://build.nvidia.com/
NVIDIA_API_KEY=your-nvidia-api-key-here

# ── Cohere / Command R+ ──────────────────────────────────────
# https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your-cohere-api-key-here

# ── Together AI (Llama 4, DeepSeek-R1, Qwen Coder, …) ───────
# https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your-together-api-key-here

# ── Groq (Llama 4 Scout, Llama 3.3, …) ──────────────────────
# https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# ============================================================
# Models WITHOUT a public API (cannot be evaluated via this tool)
# ============================================================
# MiMo-V2-Pro (Xiaomi)  — open-weight only; no hosted API endpoint
# Hy3 Preview (Tencent) — no public API announced
# Muse Spark (Meta)     — no public API announced
# Run: python scripts/evaluate_model.py --list-models  for the full list
